{
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "target": "ES2022",
    "types": [
      "node"
    ],
    "useDefineForClassFields": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src",
    "tests",
    "eslint.config.js",
    "vitest.config.ts",
    "vite.config.ts"
  ]
}
